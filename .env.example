APP_NAME=OutboundOS
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
BENCHMARK_MODE=false
DATABASE_URL=postgresql+asyncpg://outboundos:outboundos@db:5432/outboundos
REDIS_URL=redis://redis:6379/0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
TAVILY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
SECRETS_DIR=/run/secrets
SERVICE_NAME=outboundos-api
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
RATE_LIMIT_PER_MINUTE=120
